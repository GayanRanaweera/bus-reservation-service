<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>

        <!-- Console Logger -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[v${project.version}] %d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %c{1}.%M:%L - %msg%n"/>
        </Console>

        <!-- Rolling File Logger -->
        <RollingFile name="FileLogger"
                     fileName="${sys:catalina.base}/logs/BRS.log"
                     filePattern="${sys:catalina.base}/logs/BRS-%d{yyyy-MM-dd}-%i.log.gz">

            <PatternLayout pattern="[v${project.version}] %d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %c{1}.%M:%L - %msg%n"/>

            <Policies>
                <!-- Rotate daily -->
                <TimeBasedTriggeringPolicy interval="1"/>

                <!-- Rotate if file > 10MB -->
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>

            <!-- Keep last 10 files -->
            <DefaultRolloverStrategy max="10"/>

        </RollingFile>

    </Appenders>

    <Loggers>

        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Root>

    </Loggers>

</Configuration>